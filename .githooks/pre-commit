#!/usr/bin/env bash
set -euo pipefail

# Only lint if staged files include Go code under server/
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- 'server/*.go' 'server/**/*.go' || true)

if [ -z "$STAGED_GO" ]; then
  exit 0
fi

if ! command -v golangci-lint &>/dev/null; then
  echo "warning: golangci-lint not found, skipping lint (run inside nix develop shell)"
  exit 0
fi

echo "Running golangci-lint on staged Go files..."
cd server
golangci-lint run ./...
