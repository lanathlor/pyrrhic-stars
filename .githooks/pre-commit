#!/usr/bin/env bash
set -euo pipefail

STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- 'server/**/*.go' 'server/*.go' || true)
STAGED_GD=$(git diff --cached --name-only --diff-filter=ACM -- 'client/**/*.gd' 'client/*.gd' || true)

if [ -n "$STAGED_GO" ]; then
  just server lint
  just server fmt-check
  just server test
fi

if [ -n "$STAGED_GD" ]; then
  just client lint
  just client fmt-check
  just client test
fi
