---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import DevlogPost from "../../layouts/DevlogPost.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("devlog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"devlog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage } = post.data;
---

<Base title={title} description={description} image={heroImage} frAlternate={false}>
  <DevlogPost
    title={title}
    description={description}
    pubDate={pubDate}
    updatedDate={updatedDate}
    heroImage={heroImage}
  >
    <Content />
  </DevlogPost>
</Base>
