---
import Base from "../layouts/Base.astro";
import { PHASES, type PhaseStatus } from "../lib/roadmap";

export const prerender = true;

// Quiet status chip per phase. Matches the homepage section's badge language.
const statusChip: Record<PhaseStatus, { label: string; classes: string } | null> = {
  done: {
    label: "Done",
    classes: "bg-bg-overlay text-text-muted border-border-muted",
  },
  now: {
    label: "Now",
    classes: "bg-chrome-500/15 text-chrome-300 border-chrome-500/30",
  },
  next: {
    label: "Next",
    classes: "bg-bg-overlay text-text-muted border-border-muted",
  },
  later: null,
};
---

<Base
  title="Roadmap"
  description="How Pyrrhic Stars gets built: phase by phase, each ending with something concrete. What's done, what's now, and what comes next."
>
  <main class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <header class="mb-12">
      <p class="text-xs uppercase tracking-[0.2em] text-chrome-400 font-medium">
        Where this is going
      </p>
      <h1 class="mt-4 text-4xl sm:text-5xl font-semibold tracking-tight text-text-primary">
        Roadmap.
      </h1>
      <p class="mt-4 text-text-secondary leading-relaxed">
        I build this in phases. Each phase ends with something concrete: a clip,
        a playable build, a Steam page. Before the next one starts. No release
        dates, no features announced before I have started them. The repository
        is the source of truth; this page is the plan around it.
      </p>
    </header>

    <ol class="relative border-l border-border-muted pl-8 space-y-12">
      {
        PHASES.map((phase) => {
          const chip = statusChip[phase.status];
          const isNow = phase.status === "now";
          return (
            <li class="relative">
              <span
                aria-hidden="true"
                class:list={[
                  "absolute -left-[2.4rem] top-1.5 h-3 w-3 rounded-full border-2 border-bg-base",
                  isNow
                    ? "bg-chrome-400"
                    : phase.status === "done"
                      ? "bg-text-muted"
                      : "bg-border-muted",
                ]}
              />
              <div class="flex flex-wrap items-center gap-2">
                <span class="text-[11px] font-mono uppercase tracking-[0.15em] text-text-muted">
                  {phase.label}
                </span>
                {chip && (
                  <span
                    class:list={[
                      "text-[10px] px-1.5 py-0.5 rounded border font-medium",
                      chip.classes,
                    ]}
                  >
                    {chip.label}
                  </span>
                )}
              </div>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-text-primary">
                {phase.title}
              </h2>
              <p class="mt-1 text-sm text-chrome-300">{phase.goal}</p>
              <p class="mt-4 text-text-secondary leading-relaxed">
                {phase.summary}
              </p>
              <ul class="mt-5 space-y-1.5 text-sm text-text-secondary">
                {phase.bullets.map((b) => (
                  <li class="flex gap-2">
                    <span aria-hidden="true" class="text-text-muted">
                      &bull;
                    </span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </li>
          );
        })
      }
    </ol>

    <p class="mt-16 border-t border-border-muted pt-8 text-sm text-text-muted leading-relaxed">
      Phases shift as I learn what the game wants to be. If something here does
      not match the build, the build wins and I have not updated this page yet.
      Follow along on the <a href="/devlog" class="text-chrome-300 hover:text-chrome-200">devlog</a>.
    </p>
  </main>
</Base>
