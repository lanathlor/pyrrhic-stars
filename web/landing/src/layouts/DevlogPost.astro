---
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"devlog">["data"];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<article class="mx-auto max-w-3xl px-6 py-16">
  <a
    href="/devlog"
    class="group inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-chrome-300 transition-colors mb-8"
  >
    <Icon
      name="lucide:arrow-left"
      class="h-4 w-4 transition-transform group-hover:-translate-x-1"
      aria-hidden="true"
    />
    Back to devlog
  </a>

  <header class="mb-12">
    <time class="text-sm text-text-muted" datetime={pubDate.toISOString()}>
      <FormattedDate date={pubDate} />
    </time>
    {
      updatedDate && (
        <span class="ml-2 text-sm italic text-text-muted">
          (updated <FormattedDate date={updatedDate} />)
        </span>
      )
    }
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl">
      {title}
    </h1>
    {description && <p class="mt-4 text-lg text-text-secondary">{description}</p>}
  </header>

  <div
    class="prose prose-invert max-w-none
           prose-headings:font-semibold prose-headings:text-text-primary
           prose-p:text-text-secondary
           prose-a:text-chrome-300 prose-a:no-underline hover:prose-a:text-chrome-200
           prose-strong:text-text-primary
           prose-code:rounded prose-code:bg-bg-overlay prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:text-text-primary prose-code:before:content-none prose-code:after:content-none
           prose-pre:bg-bg-raised prose-pre:border prose-pre:border-border-muted
           prose-img:rounded-xl
           [&_pre_code]:p-0 [&_pre_code]:bg-transparent"
  >
    <slot />
  </div>
</article>
