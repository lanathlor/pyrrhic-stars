---
// Public roadmap (homepage section). Phase data lives in src/lib/roadmap.ts so
// this section and the full /roadmap page stay in sync. Keep it terse here;
// the full page carries the prose.

import { PHASES } from '../lib/roadmap'

const milestones = PHASES
---

<section
	id='roadmap'
	class='mx-auto max-w-6xl px-6 py-20 sm:py-28'
>
	<header class='mb-12'>
		<p class='text-xs uppercase tracking-[0.2em] text-chrome-400 font-medium'>
			Where this is going
		</p>
		<h2 class='mt-4 text-3xl sm:text-4xl font-semibold tracking-tight text-text-primary'>
			Roadmap.
		</h2>
		<p class='mt-4 max-w-2xl text-text-secondary leading-relaxed'>
			Built in phases. Each phase ends with something concrete: a clip, a playable build, a
			Steam page. Before the next one starts.
		</p>
	</header>

	<ol class='grid sm:grid-cols-2 lg:grid-cols-4 gap-4'>
		{
			milestones.map((m) => (
				<li
					class:list={[
						'relative rounded-lg border p-6 transition-colors',
						m.status === 'now'
							? 'border-chrome-500/60 bg-bg-raised'
							: 'border-border-muted bg-bg-raised',
					]}
				>
					<div class='flex items-center gap-2 mb-3'>
						<span
							class:list={[
								'text-[11px] font-mono uppercase tracking-[0.15em]',
								m.status === 'now' ? 'text-chrome-300' : 'text-text-muted',
							]}
						>
							{m.label}
						</span>
						{m.status === 'now' && (
							<span class='text-[10px] px-1.5 py-0.5 rounded bg-chrome-500/15 text-chrome-300 border border-chrome-500/30 font-medium'>
								Now
							</span>
						)}
						{m.status === 'done' && (
							<span class='text-[10px] px-1.5 py-0.5 rounded bg-bg-overlay text-text-muted border border-border-muted font-medium'>
								Done
							</span>
						)}
					</div>
					<h3 class='text-lg font-semibold text-text-primary'>{m.title}</h3>
					<ul class='mt-3 space-y-1.5 text-sm text-text-secondary leading-relaxed'>
						{m.bullets.map((b) => (
							<li>{b}</li>
						))}
					</ul>
				</li>
			))
		}
	</ol>

	<a
		href='/roadmap'
		class='mt-10 inline-flex items-center gap-1.5 text-sm text-chrome-300 hover:text-chrome-200 font-medium transition-colors'
	>
		Read the full roadmap
		<span aria-hidden='true'>&rarr;</span>
	</a>
</section>
