---
import { Icon } from 'astro-icon/components'
import CtaLinks from './CtaLinks.astro'
import { SITE_TAGLINE } from '../consts'

const repo = import.meta.env.PUBLIC_REPO_URL
---

<section class='relative overflow-hidden'>
	<!-- Subtle grid backdrop. Decoration only, kept very low contrast per the
       UI language doc ("screen humility"). -->
	<div
		aria-hidden='true'
		class='pointer-events-none absolute inset-0 opacity-[0.04]'
		style='background-image: linear-gradient(to right, #6e90b5 1px, transparent 1px), linear-gradient(to bottom, #6e90b5 1px, transparent 1px); background-size: 64px 64px;'
	>
	</div>

	<div class='relative mx-auto max-w-6xl px-6 pt-24 pb-20 sm:pt-32 sm:pb-28'>
		<div class='flex flex-wrap items-center gap-x-4 gap-y-2 animate-fade-up'>
			<p class='text-xs uppercase tracking-[0.2em] text-chrome-400 font-medium'>
				Phase 0 &middot; Proof of concept
			</p>
			{
				repo && (
					<a
						href={repo}
						target='_blank'
						rel='noopener'
						class='inline-flex items-center gap-1.5 text-xs uppercase tracking-[0.2em] text-chrome-300 hover:text-chrome-200 font-medium transition-colors'
					>
						<Icon
							name='lucide:external-link'
							width='12'
							height='12'
							aria-hidden='true'
						/>
						Open source
					</a>
				)
			}
		</div>
		<h1
			class='mt-6 text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-text-primary animate-fade-up'
			style='animation-delay: 60ms'
		>
			{SITE_TAGLINE}
		</h1>
		<p
			class='mt-6 max-w-2xl text-lg sm:text-xl text-text-secondary animate-fade-up'
			style='animation-delay: 120ms'
		>
			A sci-fi co-op dungeon crawler where the Gunner plays an FPS, the Vanguard plays a
			Souls-like, and the Blade Dancer plays a state machine, all in the same fight, against
			the same boss.
		</p>

		<div
			class='mt-10 animate-fade-up'
			style='animation-delay: 180ms'
		>
			<CtaLinks />
		</div>

		<p class='mt-6 text-sm text-text-muted'>New devlog every week.</p>
	</div>
</section>
