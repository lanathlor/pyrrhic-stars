---
// 4 feature pillars. Wording sourced from docs/design/combat.md and
// docs/design/classes/README.md. Do not rewrite. This language is what the
// design docs commit to publicly.

interface Pillar {
  title: string;
  body: string;
  tags?: string[];
}

const pillars: Pillar[] = [
  {
    title: "Six classes. Six different game genres.",
    body: "Every class has a different camera, a different input model, and a different combat loop. They share one game, one dungeon, one boss.",
    tags: [
      "FPS",
      "Souls-like",
      "Channeler",
      "Deployables",
      "Blades",
      "Auras",
    ],
  },
  {
    title: "Skill-based combat. No threat tables. No auto-attacks.",
    body: "Every point of damage a boss deals is avoidable with better play. Bosses telegraph, you read, you move. The Shield Vanguard blocks space. It doesn’t taunt.",
  },
  {
    title: "5-player co-op. No required roles.",
    body: "Healers and tanks exist. They’re strong. They’re not mandatory. Encounters are completable without them at sufficient skill.",
  },
  {
    title: "Weekly devlog. Built in public.",
    body: "One concrete thing working each week. No vapor. No mockups. Real footage, real systems, no exceptions.",
  },
];
---

<section id="features" class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.2em] text-chrome-400 font-medium">
      What makes it different
    </p>
    <h2 class="mt-4 text-3xl sm:text-4xl font-semibold tracking-tight text-text-primary">
      Four pillars.
    </h2>
  </header>

  <div class="grid sm:grid-cols-2 gap-px bg-border-muted border border-border-muted rounded-lg overflow-hidden">
    {
      pillars.map((p) => (
        <article class="bg-bg-base p-6 sm:p-8">
          <h3 class="text-lg sm:text-xl font-semibold text-text-primary">{p.title}</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">{p.body}</p>
          {p.tags && (
            <ul class="mt-5 flex flex-wrap gap-2 text-xs font-medium text-text-muted">
              {p.tags.map((t) => (
                <li class="px-2 py-1 rounded border border-border-muted bg-bg-raised">
                  {t}
                </li>
              ))}
            </ul>
          )}
        </article>
      ))
    }
  </div>
</section>
