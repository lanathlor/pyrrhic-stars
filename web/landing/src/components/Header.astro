---
import { Icon } from "astro-icon/components";
import { NAV, SITE_TITLE, REPO_URL } from "../consts";
import { getLang, useTranslations, localePath, neutralPath } from "../i18n/utils";
import LangSwitcher from "./LangSwitcher.astro";

interface Props {
  /** Forwarded to LangSwitcher; false on pages with no localized counterpart. */
  hasCounterpart?: boolean;
}

const { hasCounterpart = true } = Astro.props;
const lang = getLang(Astro);
const t = useTranslations(lang);
const repo = REPO_URL;

// Compare against the locale-neutral path so /fr/about highlights "About".
const pathname = neutralPath(Astro.url.pathname).replace(/\/$/, "") || "/";

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-bg-base/70 border-b border-border-muted">
  <div class="mx-auto max-w-6xl px-6 h-14 flex items-center justify-between">
    <a href={localePath(lang, "/")} class="flex items-center gap-2 text-text-primary font-semibold tracking-tight">
      <Icon name="logo" width="22" height="22" aria-hidden="true" />
      <span>{SITE_TITLE}</span>
    </a>

    {/* Desktop nav. Collapses into the menu button below the md breakpoint. */}
    <nav aria-label="Primary" class="hidden md:flex items-center gap-1 text-sm">
      {
        NAV.map((item) => (
          <a
            href={localePath(lang, item.href)}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "px-3 py-1.5 rounded-md transition-colors",
              isActive(item.href)
                ? "text-text-primary bg-bg-raised"
                : "text-text-muted hover:text-text-primary",
            ]}
          >
            {t(item.key)}
          </a>
        ))
      }
      {
        repo && (
          <a
            href={repo}
            target="_blank"
            rel="noopener"
            aria-label={t("header.github")}
            class="ml-1 p-1.5 rounded-md text-text-muted hover:text-text-primary transition-colors"
          >
            <Icon name="simple-icons:github" width="18" height="18" aria-hidden="true" />
          </a>
        )
      }
      <span class="ml-2"><LangSwitcher hasCounterpart={hasCounterpart} /></span>
    </nav>

    {/* Mobile menu toggle. */}
    <button
      type="button"
      id="nav-toggle"
      aria-label={t("header.menu")}
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="md:hidden -mr-1.5 p-1.5 rounded-md text-text-muted hover:text-text-primary transition-colors"
    >
      <Icon name="lucide:menu" class="nav-icon-open" width="22" height="22" aria-hidden="true" />
      <Icon name="lucide:x" class="nav-icon-close hidden" width="22" height="22" aria-hidden="true" />
    </button>
  </div>

  {/* Mobile nav panel. Hidden until toggled; no md+ render. */}
  <nav
    id="mobile-nav"
    aria-label="Primary"
    class="hidden md:hidden border-t border-border-muted bg-bg-base/95 backdrop-blur-md"
  >
    <div class="mx-auto max-w-6xl px-6 py-3 flex flex-col gap-0.5 text-sm">
      {
        NAV.map((item) => (
          <a
            href={localePath(lang, item.href)}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "px-3 py-2.5 rounded-md transition-colors",
              isActive(item.href)
                ? "text-text-primary bg-bg-raised"
                : "text-text-muted hover:text-text-primary",
            ]}
          >
            {t(item.key)}
          </a>
        ))
      }
      <div class="mt-2 pt-3 border-t border-border-muted flex items-center justify-between">
        <LangSwitcher hasCounterpart={hasCounterpart} />
        {
          repo && (
            <a
              href={repo}
              target="_blank"
              rel="noopener"
              aria-label={t("header.github")}
              class="p-1.5 rounded-md text-text-muted hover:text-text-primary transition-colors"
            >
              <Icon name="simple-icons:github" width="18" height="18" aria-hidden="true" />
            </a>
          )
        }
      </div>
    </div>
  </nav>
</header>

<script>
  // Toggle the mobile nav panel. Progressive enhancement: without JS the panel
  // stays hidden, but every nav target is still reachable from the footer and
  // in-page links, so the page remains usable.
  const btn = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  if (btn && panel) {
    const iconOpen = btn.querySelector(".nav-icon-open");
    const iconClose = btn.querySelector(".nav-icon-close");

    const setOpen = (open: boolean) => {
      panel.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", String(open));
      iconOpen?.classList.toggle("hidden", open);
      iconClose?.classList.toggle("hidden", !open);
    };

    btn.addEventListener("click", () => {
      setOpen(panel.classList.contains("hidden"));
    });

    // Close after picking a destination, or on Escape.
    panel.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => setOpen(false));
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        (btn as HTMLButtonElement).focus();
      }
    });
  }
</script>
