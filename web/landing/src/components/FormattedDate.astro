---
import { getLang } from "../i18n/utils";

interface Props {
  date: Date;
}

const { date } = Astro.props;
const locale = getLang(Astro) === "fr" ? "fr-FR" : "en-US";
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(locale, {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  }
</time>
