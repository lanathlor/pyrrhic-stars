---
import { SITE_TITLE, DISCORD_URL, REPO_URL } from "../consts";
import { getLang, useTranslations, localePath } from "../i18n/utils";

const lang = getLang(Astro);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const discord = DISCORD_URL;
const repo = REPO_URL;
---

<footer class="mt-24 border-t border-border-muted">
  <div class="mx-auto max-w-6xl px-6 py-10 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between text-sm text-text-muted">
    <p>&copy; {year} {SITE_TITLE}. {t("footer.builtInPublic")}</p>
    <div class="flex items-center gap-4">
      <a href={localePath(lang, "/devlog")} class="hover:text-text-primary transition-colors">{t("footer.devlog")}</a>
      <a href="/rss.xml" class="hover:text-text-primary transition-colors">{t("footer.rss")}</a>
      {
        repo && (
          <a
            href={repo}
            target="_blank"
            rel="noopener"
            class="hover:text-text-primary transition-colors"
          >
            {t("footer.github")}
          </a>
        )
      }
      {
        discord && (
          <a
            href={discord}
            target="_blank"
            rel="noopener"
            class="hover:text-text-primary transition-colors"
          >
            {t("footer.discord")}
          </a>
        )
      }
    </div>
  </div>
</footer>
