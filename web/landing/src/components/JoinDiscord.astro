---
import { Icon } from "astro-icon/components";

// Bottom CTA: join the Discord. Replaces the email signup form. The button
// gracefully degrades when PUBLIC_DISCORD_URL is unset (disabled, "Soon"),
// mirroring CtaLinks.astro.
const discord = import.meta.env.PUBLIC_DISCORD_URL;
---

<section id="join" class="mx-auto max-w-3xl px-6 py-20 sm:py-28">
  <div class="rounded-lg border border-border-muted bg-bg-raised p-8 sm:p-10">
    <p class="text-xs uppercase tracking-[0.2em] text-chrome-400 font-medium">
      Join the community
    </p>
    <h2 class="mt-3 text-2xl sm:text-3xl font-semibold tracking-tight text-text-primary">
      Follow along on Discord.
    </h2>
    <p class="mt-3 text-text-secondary">
      I post progress there as it happens. Come hang out, or tell me what is not
      working.
    </p>

    <div class="mt-6">
      <a
        href={discord || "#"}
        aria-disabled={!discord}
        target={discord ? "_blank" : undefined}
        rel={discord ? "noopener" : undefined}
        class:list={[
          "inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-medium transition-colors border",
          discord
            ? "bg-chrome-500 text-text-primary border-chrome-500 hover:bg-chrome-400 hover:border-chrome-400"
            : "bg-bg-raised text-text-muted border-border-muted cursor-not-allowed pointer-events-none",
        ]}
      >
        <Icon name="simple-icons:discord" width="16" height="16" aria-hidden="true" />
        {discord ? "Join Discord" : "Discord: Soon"}
      </a>
    </div>
  </div>
</section>
