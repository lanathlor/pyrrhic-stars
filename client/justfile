set dotenv-load := false
set shell := ["bash", "-euo", "pipefail", "-c"]

# List available commands
default:
    @just --list

# --- Lint & Format ---

# Format all GDScript files
fmt:
    gdformat scripts/ scenes/ tests/

# Check formatting without writing changes
fmt-check:
    gdformat --check scripts/ scenes/ tests/

# Show formatting diff without writing changes
fmt-diff:
    gdformat --diff scripts/ scenes/ tests/

# Lint all GDScript files
lint:
    gdlint scripts/ scenes/
    cd tests/ && gdlint .

# Check function body length (max 60 lines)
funlen:
    python3 scripts/tools/check_func_length.py scripts/ scenes/

# Run both lint and format check
check: fmt-check lint funlen

# --- Tests ---

# Run all GdUnit tests
test:
    godot --headless -s addons/gdUnit4/bin/GdUnitCmdTool.gd -a res://tests -c --ignoreHeadlessMode

# Run a single test suite
test-suite suite:
    godot --headless -s addons/gdUnit4/bin/GdUnitCmdTool.gd -a res://tests/{{suite}}.gd -c --ignoreHeadlessMode

# --- Run ---

# Launch Godot
run:
    godot

# Launch Godot in dev mode (debug panel, auto-start server)
run-dev class="":
    godot -- --dev {{ if class != "" { "--class=" + class } else { "" } }}

# Launch Godot editor
editor:
    godot --editor

# Bot plays the game (watch it go)
bot:
    godot -- --bot --capture

# Vanguard bot plays the game
bot-vanguard:
    godot -- --bot --capture --class=vanguard

# Headless bot run for CI (default 30s, override with duration=N)
e2e duration="30":
    godot -- --bot --capture --e2e --duration={{duration}}

# Headed bot run (watch the bot + get e2e result)
e2e-visual duration="30":
    godot -- --bot --capture --e2e --duration={{duration}}

# Vanguard e2e
e2e-vanguard duration="30":
    godot -- --bot --capture --e2e --class=vanguard --duration={{duration}}

# Remote control mode
remote:
    godot -- --remote --capture

# --- Web Export ---

# Download Godot export templates (needed once)
web-install-templates:
    #!/usr/bin/env bash
    set -euo pipefail
    FULL=$(godot --version)
    VERSION=$(echo "$FULL" | cut -d. -f1-3)
    STATUS=$(echo "$FULL" | cut -d. -f4)
    TEMPLATE_DIR="$HOME/.local/share/godot/export_templates/${VERSION}.${STATUS}"
    if [ -d "$TEMPLATE_DIR" ] && ls "$TEMPLATE_DIR"/web_* 1>/dev/null 2>&1; then
        echo "Export templates already installed at $TEMPLATE_DIR"
        exit 0
    fi
    echo "Downloading Godot ${VERSION}-${STATUS} export templates..."
    mkdir -p "$TEMPLATE_DIR"
    TMPDIR=$(mktemp -d)
    trap 'rm -rf "$TMPDIR"' EXIT
    curl -L --progress-bar \
        "https://github.com/godotengine/godot/releases/download/${VERSION}-${STATUS}/Godot_v${VERSION}-${STATUS}_export_templates.tpz" \
        -o "$TMPDIR/templates.tpz"
    unzip -q "$TMPDIR/templates.tpz" -d "$TMPDIR"
    cp "$TMPDIR"/templates/* "$TEMPLATE_DIR/"
    echo "Templates installed to $TEMPLATE_DIR"

# Export client as web build
web-export: web-install-templates
    mkdir -p ../build/web
    godot --headless --export-release "Web" ../build/web/index.html
