set dotenv-load := false

gopath := `pwd` + "/.go"
export GOPATH := gopath

# List available commands
default:
    @just --list

# --- Run ---

# Run the gateway server
run-gateway:
    go run ./cmd/gateway/

# Run the zone server
run-zone:
    go run ./cmd/zone/

# Run the chat server
run-chat:
    go run ./cmd/chat/

# --- Test ---

# Run all tests (unit + integration)
test:
    go test ./... -count=1

# Run unit tests only (message + relay)
test-unit:
    go test ./internal/message/ ./internal/relay/ -count=1

# Run integration tests only
test-integration:
    go test ./internal/integration/ -v -count=1

# Run all tests with race detector
test-race:
    go test ./... -race -count=1

# --- Build ---

# Build all packages
build:
    go build ./...

# Tidy go.mod and go.sum
tidy:
    go mod tidy

# Run go vet on all packages
vet:
    go vet ./...
